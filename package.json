{
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "prebuild": "node -e \"if (process.platform !== 'win32') require('fs').chmodSync('node_modules/.bin/vite', 0o755)\"",
    "build": "node -e \"try{ if (process.platform !== 'win32') require('fs').chmodSync('node_modules/.bin/vite', 0o755) }catch(e){}\" && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "vite": "^7.3.1"
  },
  "engines": {
    "node": "24.x"
  }
}